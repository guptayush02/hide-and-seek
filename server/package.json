{
  "name": "hide-and-seek-server",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build:client": "cd ../client && npm run build",
    "sync:public": "rm -rf public && mkdir -p public && cp -R ../client/dist/* public/",
    "prepare:ui": "npm run build:client && npm run sync:public"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "mongodb": "^4.13.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
